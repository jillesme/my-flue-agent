{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "my-flue-agent",
  "compatibility_date": "2026-07-10",
  "compatibility_flags": ["nodejs_compat"],
  "ai": {
    "binding": "AI"
  },
  "d1_databases": [
    {
      "binding": "WATCHTOWER_DB",
      "database_name": "world-cup-signal-news",
      "database_id": "74dd6053-787f-4223-9ef2-1b3a32e5d699",
      "migrations_dir": "migrations"
    }
  ],
  "triggers": {
    "crons": ["*/30 * * * *"]
  },
  "assets": {
    "directory": "./dist/client",
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/api/*", "/health"]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["FlueRegistry", "FlueWorldCupSignalAgent"]
    },
    {
      "tag": "v2",
      "new_sqlite_classes": ["FlueRefreshWatchtowerWorkflow"]
    }
  ]
}
